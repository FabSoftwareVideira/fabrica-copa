NODE_ENV=development # Pode ser 'development' ou 'production'
PORT=3001
JWT_SECRET=troque-este-segredo

# Frontends permitidos (localhost + rede local)
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://192.168.1.8:5173

# URL pública usada em links retornados pela API
PUBLIC_BASE_URL=http://localhost:3001

# Logging backend
LOG_LEVEL=debug # Níveis: error, warn, info, debug

# Auth
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30