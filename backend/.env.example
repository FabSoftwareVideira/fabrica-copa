NODE_ENV=development # Pode ser 'development' ou 'production'
PORT=3001
JWT_SECRET=troque-este-segredo

# Frontends permitidos (localhost + rede local)
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://192.168.1.8:5173

# URL pública usada em links retornados pela API
PUBLIC_BASE_URL=http://localhost:3001

# Logging backend
LOG_LEVEL=debug # Níveis: error, warn, info, debug
LOG_ROTATION_ENABLED=false # Em produção recomenda-se true
LOG_DIR=./backend/logs
LOG_ROTATION_INTERVAL=1d # Ex: 1d, 12h
LOG_ROTATION_MAX_FILES=14

# Auth
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# Google OAuth
GOOGLE_CLIENT_ID=seu-google-client-id.apps.googleusercontent.com

# Caminho para base de dados SQLite (apenas para produção)
HOST_BACKUP_DIR=./backups
HOST_DB_DIR=./data
HOST_UPLOAD_DIR=./data/uploads
HOST_LOG_DIR=./logs
# HOST_BACKUP_DIR=/srv/fabrica-copa-backups
# HOST_DB_DIR=/srv/fabrica-copa-data
# HOST_UPLOAD_DIR=/srv/fabrica-copa-data/uploads
# HOST_LOG_DIR=/srv/fabrica-copa-logs